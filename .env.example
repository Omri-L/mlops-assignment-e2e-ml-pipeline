# Required: Nebius inference API key
NEBIUS_API_KEY=XXX

# Optional: UID of the Airflow process (default: 50000).
# On Linux, set this to $(id -u) to match your host user.
AIRFLOW_UID=50000

# PostgreSQL credentials (default: airflow/airflow)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow secrets — change these in any non-local deployment
AIRFLOW__WEBSERVER__SECRET_KEY=changeme
# Generate a new Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
